---
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import OceanBackground from '../components/OceanBackground.astro';
import MotionEnhancements from '../components/MotionEnhancements.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
}

const { title, description, image, type, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;700&family=Playfair+Display:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <SEO title={title} description={description} image={image} type={type} jsonLd={jsonLd} />
    <script is:inline>document.documentElement.classList.add('js');</script>

<!-- Google Analytics -->
{import.meta.env.PUBLIC_GA_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
    <script define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}

  </head>
  <body class="relative min-h-screen text-ink antialiased">
    <OceanBackground />
    <div class="relative z-[1]">
      <main class="min-h-[50vh] overflow-x-hidden">
        <slot />
      </main>
      <Footer />
    </div>
    <MotionEnhancements />

    <script is:inline>
      (() => {
        /** 掃描 root 內所有 <img>（預設為整頁） */
        function scanAllImages(root = document) {
          return Array.from(root.querySelectorAll('img'));
        }

        /** Cloudinary 圖片自動加上 f_auto,q_auto 轉換 */
        function onImagesReady(images) {
          images.forEach((img) => {
            const src = img.getAttribute('src');
            if (src && src.includes('res.cloudinary.com') && !src.includes('f_auto')) {
              img.src = src.replace('/upload/', '/upload/f_auto,q_auto/');
            }
          });
        }

        /** 移除文章數為 0 的分類（含快取舊版 HTML） */
        function hideZeroCountCategories(root = document) {
          const widgets = root.querySelectorAll('[data-sidebar-categories], .sidebar-widget');
          widgets.forEach((widget) => {
            const title = widget.querySelector('.sidebar-section-title');
            if (!title || title.textContent.trim() !== '文章分類') return;

            widget.querySelectorAll('ul > li').forEach((li) => {
              const attrCount = li.getAttribute('data-category-count');
              const badge = li.querySelector('[data-count], span.rounded-full');
              const count = attrCount ?? badge?.getAttribute('data-count') ?? badge?.textContent?.trim();
              if (count === '0' || Number(count) === 0) li.remove();
            });

            const list = widget.querySelector('ul');
            if (list && !list.children.length) widget.remove();
          });
        }

        function onPageReady() {
          onImagesReady(scanAllImages());
          hideZeroCountCategories();
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', onPageReady, { once: true });
        } else {
          onPageReady();
        }
      })();
    </script>

    <a href="mailto:service@royal-cruiser.com" class="fab-frap" aria-label="快速聯絡 service@royal-cruiser.com" data-enter="up" data-enter-delay="1100">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </a>
  </body>
</html>
