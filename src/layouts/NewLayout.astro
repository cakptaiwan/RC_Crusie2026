---
import { categoryHref, newLayoutNavSections } from '../data/new-layout-nav';
import { newHomeUrl } from '../lib/new-article-url';
import { socialLinks } from '../data/social-links';
import ContactPanel from '../components/ContactPanel.astro';

export interface Props {
  title: string;
  description?: string;
  navActive?: string;
}

const { title, description, navActive = '' } = Astro.props;
const fbLink = socialLinks[0];
const [footerCol1, footerCol2, footerCol3, footerCol4] = newLayoutNavSections;
const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="icon" type="image/png" href="/assets/favicon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@700;900&family=Noto+Sans+TC:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/reveal/reveal-animation.css">
<style is:global>
body{margin:0;background:#EDF4FA;font-family:'Noto Sans TC',sans-serif}
.srf{font-family:'Noto Serif TC',serif}
.mono{font-family:ui-monospace,'SF Mono',Menlo,monospace}
.art{width:100%;background:#fff;position:relative}
.ph{width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.2,.7,.2,1)}
.zi{overflow:hidden}
.zi:hover .ph{transform:scale(1.05)}
.ovl{font-size:12px;letter-spacing:.24em;color:#3E6C97;font-weight:700;text-transform:uppercase}
.navy{color:#0B2A4A}
.soc{width:30px;height:30px;border:1px solid rgba(11,42,74,.35);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;letter-spacing:.04em;color:inherit;font-weight:700}
.wsoc{border-color:rgba(255,255,255,.55)}
.alink{color:#0B2A4A;font-weight:600;font-size:14px;text-decoration:none;border-bottom:1px solid rgba(11,42,74,.4);padding-bottom:2px;transition:opacity .25s}
.alink:hover{opacity:.6}
a{color:#0B2A4A}
a:hover{opacity:.75}
.a-nav{display:flex;justify-content:space-between;align-items:center;padding:20px 56px;border-bottom:1px solid rgba(11,42,74,.16);color:#0B2A4A;position:relative;z-index:5;background:#fff}
.a-links{display:flex;gap:38px;font-size:15px;font-weight:400}
.a-sec{padding:72px 56px 88px;color:#0B2A4A}
.a-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:46px}
.a-h2{font-size:42px;font-weight:900;margin:12px 0 0;letter-spacing:.02em}
.a-grid{display:grid;grid-template-columns:1.35fr 1fr;gap:64px}
.a-leadimg{aspect-ratio:3/2;margin-bottom:26px}
.a-cat{color:#2A628F;font-weight:700;font-size:12px;letter-spacing:.2em}
.a-date{color:#8AA3B9;font-size:12px;letter-spacing:.1em}
.a-h3{font-size:29px;line-height:1.45;font-weight:700;margin:10px 0 12px}
.a-ex{color:#51677C;font-size:15px;line-height:1.95;margin:0 0 18px}
.a-row{display:grid;grid-template-columns:44px 1fr 132px;gap:22px;padding:24px 0;border-top:1px solid rgba(11,42,74,.16);align-items:center;text-decoration:none;transition:background .3s}
.a-row:hover{background:rgba(11,42,74,.04)}
.a-num{font-size:26px;color:#9FB9CE;font-weight:700}
.a-rt{font-size:18px;font-weight:700;color:#0B2A4A;line-height:1.55;margin:6px 0}
.a-thumb{width:132px;aspect-ratio:3/2;height:auto}
.c-hero{position:relative}
.tband{background:#EAF3FA;border-radius:26px;padding:34px}
.ticket{display:flex;align-items:stretch;background:#fff;border-radius:16px;box-shadow:0 26px 64px rgba(11,42,74,.18)}
.tmain{flex:1;display:flex;flex-direction:column;min-width:0}
.tkhd{background:#0B2A4A;color:#fff;padding:15px 44px;display:flex;justify-content:space-between;align-items:center;font-size:13px;font-weight:700;letter-spacing:.22em;border-radius:16px 0 0 0}
.tkhd2{border-radius:0 16px 0 0;padding:15px 30px;font-size:12px}
.tbody{position:relative;flex:1;padding:30px 44px 24px;overflow:hidden}
.tship{position:absolute;right:-30px;bottom:-14px;width:62%;opacity:.4;pointer-events:none}
.tin{position:relative}
.coderow{display:flex;gap:26px}
.codelbl{font-size:10px;letter-spacing:.22em;color:#8AA3B9;font-weight:700}
.codeval{font-size:19px;font-weight:700;color:#0B2A4A;margin-top:3px}
.bph1{font-size:52px;font-weight:900;color:#0B2A4A;line-height:1.35;margin:14px 0}
.route{display:flex;align-items:center;gap:18px}
.rl{font-size:10px;letter-spacing:.22em;color:#8AA3B9;font-weight:700}
.rc{font-size:22px;font-weight:900;color:#0B2A4A;letter-spacing:.03em;line-height:1.2}
.rsub{font-size:12px;color:#51677C;letter-spacing:.08em}
.rline{flex:1;display:flex;align-items:center;gap:8px;color:#4A729B}
.rdash{flex:1;border-top:2px dashed #9FB9CE;height:0}
.rdot{width:7px;height:7px;border-radius:50%;background:#4A729B;flex-shrink:0}
.tfoot{display:flex;justify-content:space-between;align-items:center;gap:36px;border-top:1px solid rgba(11,42,74,.12);padding:18px 44px 22px}
.tnote{font-size:11px;letter-spacing:.12em;color:#8AA3B9;font-weight:600}
.bar{height:36px;background:repeating-linear-gradient(90deg,#0B2A4A 0 2px,transparent 2px 5px,#0B2A4A 5px 7px,transparent 7px 11px,#0B2A4A 11px 12px,transparent 12px 16px)}
.tstub{width:330px;flex-shrink:0;border-left:2px dashed #B9CFE2;position:relative;display:flex;flex-direction:column}
.snotch{position:absolute;width:30px;height:30px;border-radius:50%;background:#EAF3FA;left:-16px}
.tsbody{padding:26px 30px 28px;flex:1;display:flex;flex-direction:column;gap:18px}
.ex2{color:#51677C;font-size:14px;line-height:1.85;margin:0}
.wm{display:flex;align-items:baseline;gap:12px}
.logo{width:42px;height:42px;border-radius:50%;display:block;flex-shrink:0}
.brand{display:flex;align-items:center;gap:14px}
.wm1{font-size:22px;font-weight:900;letter-spacing:.06em}
.wm2{font-size:10px;letter-spacing:.28em;opacity:.65;font-weight:600}
.wex{color:rgba(255,255,255,.8)}
.main2{display:grid;grid-template-columns:1fr 300px;gap:72px;padding:0 56px 96px;color:#0B2A4A;position:relative;z-index:1}
.sec-head{display:flex;justify-content:space-between;align-items:flex-end;margin:80px 0 40px}
.t-lead{display:grid;grid-template-columns:1.1fr 1fr;gap:40px;align-items:center;text-decoration:none;color:inherit}
.t-leadimg{aspect-ratio:3/2}
.t-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 56px;margin-top:16px}
.t-cell{display:grid;grid-template-columns:1fr 110px;gap:20px;padding:24px 0;border-top:1px solid rgba(11,42,74,.16);align-items:center;text-decoration:none;color:inherit;transition:background .3s}
.t-cell:hover{background:rgba(11,42,74,.04)}
.t-thumb{width:110px;aspect-ratio:3/2;height:auto}
.l-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 56px}
.l-row{display:grid;grid-template-columns:96px 1fr;gap:18px;padding:20px 0;border-top:1px solid rgba(11,42,74,.16);align-items:center;text-decoration:none;color:inherit;transition:background .3s}
.l-row:hover{background:rgba(11,42,74,.04)}
.l-thumb{width:96px;aspect-ratio:3/2;height:auto}
.l-t{font-size:15.5px;font-weight:700;line-height:1.6;margin:5px 0;display:block}
.sb{border-top:1px solid rgba(11,42,74,.16);padding:28px 0}
.sbh{display:flex;align-items:center;gap:12px}
.sbt{font-size:21px;font-weight:900;color:#0B2A4A;letter-spacing:.04em}
.sbh .ovl{margin-left:auto;font-size:10px}
.sbp{color:#51677C;font-size:13.5px;line-height:1.9;margin:14px 0 0}
.inp{border:1px solid rgba(11,42,74,.3);padding:10px 14px;font-size:13px;flex:1;background:transparent;font-family:inherit;color:#0B2A4A;min-width:0}
.btn{background:#0B2A4A;color:#fff;padding:10px 20px;font-size:13px;font-weight:600;letter-spacing:.08em;border:none;cursor:pointer;transition:opacity .25s}
.btn:hover{opacity:.85}
.obtn{display:inline-block;border:1px solid rgba(11,42,74,.4);color:#0B2A4A;padding:10px 22px;font-size:13px;font-weight:600;letter-spacing:.06em;text-decoration:none;transition:background .3s}
.obtn:hover{background:rgba(11,42,74,.06)}
.catrow{display:flex;justify-content:space-between;align-items:center;padding:11px 0;font-size:14px;border-bottom:1px dashed rgba(11,42,74,.2);color:#33506B;text-decoration:none;transition:color .25s}
.catrow:hover{color:#0B2A4A}
.catn{font-size:11px;color:#8AA3B9}
.ft{background:#0B2A4A;color:#fff;padding:64px 56px 0}
.ftgrid{display:grid;grid-template-columns:1fr 1fr 1.7fr 1fr 1fr;gap:48px;align-items:start}
.ftc{text-align:center}
.ftbrand{display:flex;flex-direction:column;align-items:center;text-align:center}
.fth{font-size:14px;font-weight:700;letter-spacing:.12em;margin:0 0 16px}
.ftl{display:block;color:rgba(255,255,255,.7);font-size:13px;padding:6px 0;text-decoration:none;transition:color .25s}
.ftl:hover{color:#fff}
.ftbar{display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,.18);margin-top:56px;padding:22px 0 28px;font-size:12px;color:rgba(255,255,255,.6)}
.crumb{display:flex;gap:10px;align-items:center;font-size:12.5px;color:#8AA3B9;padding:20px 56px 0;letter-spacing:.04em;position:relative;z-index:1;max-width:980px;margin-left:auto;margin-right:auto;box-sizing:border-box}
.crumb a{color:#3E6C97;text-decoration:none;transition:color .25s}
.crumb a:hover{color:#0B2A4A}
.nl{position:relative;cursor:pointer;padding-bottom:5px}
.nl::after{content:'';position:absolute;left:0;bottom:0;width:0;height:2px;background:#0B2A4A;transition:width .35s ease}
.nl:hover::after{width:100%}
.navon::after{width:100%}
.ah{padding:30px 56px 0;color:#0B2A4A;max-width:980px;margin-left:auto;margin-right:auto;box-sizing:border-box;position:relative;z-index:1}
.ah1{font-size:40px;line-height:1.45;font-weight:900;margin:16px 0 16px}
.ameta{display:flex;gap:10px;align-items:center;color:#8AA3B9;font-size:13px;letter-spacing:.04em}
.aheroimg{aspect-ratio:3/2;margin:34px auto 0;max-width:980px;box-sizing:border-box}
.abody{color:#33506B;font-size:16px;line-height:2.05;max-width:980px;margin-left:auto;margin-right:auto;box-sizing:border-box;padding:38px 56px 64px}
.abody p{margin:0 0 26px}
.abody a{color:#3E6C97;text-decoration:underline}
.abody strong{color:#0B2A4A;font-weight:700}
.abody img{max-width:100%;height:auto;border-radius:8px;margin:20px 0}
.abody ol{margin:0 0 26px;padding-left:22px}
.abody ol li{margin:7px 0;font-size:15px;line-height:1.9}
.bh2{display:flex;align-items:center;gap:14px;font-size:26px;font-weight:900;color:#0B2A4A;margin:52px 0 22px}
.bh3{font-size:20px;line-height:1.5;font-weight:900;color:#0B2A4A;margin:32px 0 14px}
.stamp{font-size:11px;font-weight:700;letter-spacing:.14em;color:#3E6C97;border:1px solid rgba(62,108,151,.35);padding:5px 12px;display:inline-block}
.kbox{border:2px dashed #B9CFE2;background:#F4F9FD;padding:24px 30px;margin:8px 0 34px}
.tocbox{border:2px dashed #B9CFE2;background:#F4F9FD;padding:24px 30px;margin:0 0 34px}
.toch{cursor:pointer;list-style:none;font-size:12px;letter-spacing:.24em;color:#3E6C97;font-weight:700}
.toch::-webkit-details-marker{display:none}
.toch::marker{display:none}
.toclist{margin:14px 0 0;padding-left:22px}
.tocli{margin:7px 0;font-size:15px;line-height:1.9}
.tocli a{color:#33506B;text-decoration:none;transition:color .2s}
.tocli a:hover{color:#0B2A4A;text-decoration:underline}
.kh{font-size:12px;letter-spacing:.24em;color:#3E6C97;font-weight:700;margin-bottom:12px}
.kul{margin:0;padding-left:22px}
.kli{margin:7px 0;font-size:15px;line-height:1.9}
.tip{background:#FFFFFF;border:none;border-left:4px solid #3E6C97;padding:20px 28px;margin:30px 0;font-size:14.5px;line-height:2;color:#33506B}
.tbl{width:100%;border-collapse:collapse;margin:28px 0;font-size:14.5px}
.tbl-scroll{max-width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch;margin:20px 0}
.th{text-align:left;padding:12px 16px;background:#0B2A4A;color:#fff;font-weight:700;font-size:13px;letter-spacing:.08em}
.th strong,.th a{color:#fff}
.td{padding:13px 16px;border-bottom:1px solid rgba(11,42,74,.16);color:#33506B}
.tagrow{display:flex;gap:10px;align-items:center;margin:44px 0 0}
.authbox{border:2px dashed #B9CFE2;padding:26px 30px;margin:44px 0 0;display:flex;gap:22px;align-items:flex-start}
.avat{width:56px;height:56px;border-radius:50%;background:#0B2A4A;color:#fff;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:900;flex-shrink:0}
.fx{display:flex}.col{flex-direction:column}.ac{align-items:center}.jc{justify-content:center}.jb{justify-content:space-between}.f1{flex:1}.noshrink{flex-shrink:0}.wrap{flex-wrap:wrap}
.fw5{font-weight:400}.fw6{font-weight:600}.fw7{font-weight:700}.fw8{font-weight:800}
.fs11{font-size:11px}.fs12{font-size:12px}.fs13{font-size:13px}.fs14{font-size:14px}.fs15{font-size:15px}.fs16{font-size:16px}.fs20{font-size:20px}.fs22{font-size:22px}
.upper{text-transform:uppercase}.tc{text-align:center}.nowrap{white-space:nowrap}
.gap8{gap:8px}.gap10{gap:10px}.gap12{gap:12px}.gap16{gap:16px}.gap24{gap:24px}
.m0{margin:0}.mt8{margin-top:8px}.mt12{margin-top:12px}.mt16{margin-top:16px}.mb8{margin-bottom:8px}.mb12{margin-bottom:12px}.mb16{margin-bottom:16px}
.posrel{position:relative}.posabs{position:absolute}.round{border-radius:999px}.ohide{overflow:hidden}.pointer{cursor:pointer}.w100{width:100%}.b0{border:0}
.nav-item{position:relative}
.nav-drop{display:none;position:absolute;top:calc(100% + 4px);left:0;z-index:20;min-width:11rem;padding:6px 0;background:#fff;border:1px solid rgba(11,42,74,.16);box-shadow:0 8px 24px rgba(11,42,74,.12)}
.nav-item:hover .nav-drop,.nav-item:focus-within .nav-drop{display:block}
.nav-drop a{display:block;padding:8px 16px;font-size:14px;font-weight:400;color:#33506B;text-decoration:none;white-space:nowrap;opacity:1}
.nav-drop a:hover{color:#0B2A4A;background:rgba(11,42,74,.04);opacity:1}
.nav-toggle{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
.nav-burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:36px;height:36px;padding:6px;cursor:pointer;border:1px solid rgba(11,42,74,.25);border-radius:8px;background:transparent}
.nav-burger span{display:block;height:2px;background:#0B2A4A;border-radius:1px;transition:transform .25s}
.nav-mobile{display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border-bottom:1px solid rgba(11,42,74,.16);box-shadow:0 12px 32px rgba(11,42,74,.12);padding:12px 20px 20px;z-index:30;max-height:calc(100vh - 72px);overflow-y:auto}
.nav-m-sec{padding:14px 0;border-bottom:1px solid rgba(11,42,74,.1)}
.nav-m-sec:last-child{border-bottom:none}
.nav-m-hd{font-size:11px;font-weight:700;letter-spacing:.18em;color:#3E6C97;margin-bottom:8px}
.nav-m-link{display:block;padding:9px 0;font-size:15px;font-weight:400;color:#33506B;text-decoration:none}
.nav-m-link:hover{color:#0B2A4A}
.crumb-title,.ah1,.a-h3,.l-t,.a-rt{overflow-wrap:anywhere;word-break:break-word}
.crumb{flex-wrap:wrap}
@media (max-width:900px){
html,body{overflow-x:hidden}
.a-nav{padding:16px 16px;flex-wrap:wrap}
.a-links{display:none}
.nav-burger{display:flex}
.nav-toggle:checked~.nav-mobile{display:block}
.nav-toggle:checked+.brand+.a-links+.fx .nav-burger span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-toggle:checked+.brand+.a-links+.fx .nav-burger span:nth-child(2){opacity:0}
.nav-toggle:checked+.brand+.a-links+.fx .nav-burger span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.main2{grid-template-columns:1fr;gap:32px;padding:0 16px 64px}
.c-hero{margin:16px 16px 0!important}
.crumb{padding:16px 16px 0}
.ah{padding:16px 16px 0}
.ah1{font-size:26px;line-height:1.4}
.aheroimg{margin:20px auto 0;padding:0 16px;max-width:100%}
.abody{padding:24px 16px 48px;max-width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch}
.ft{padding:48px 16px 0}
.a-h2{font-size:30px}
.a-h3{font-size:22px}
.bh2{font-size:21px;margin:36px 0 16px}
.a-head{margin-bottom:32px;flex-wrap:wrap;gap:12px}
.sec-head{margin:48px 0 28px;flex-wrap:wrap;gap:12px}
.a-grid,.t-grid,.l-grid,.ftgrid{grid-template-columns:1fr}
.ftgrid{gap:28px}
.ftgrid>.ftc{display:none}
.ftbrand{grid-column:1/-1}
.t-lead{grid-template-columns:1fr;gap:24px}
.a-sec{padding:48px 0 64px}
.a-sec .a-head{padding:0 16px}
.a-sec .a-grid>.rev.rev-r{padding:0 16px;box-sizing:border-box}
.a-lead{display:grid;grid-template-columns:1fr;gap:24px}
.a-sec .lead-body{padding:0 16px;width:auto;max-width:100%}
.a-leadimg,.t-leadimg{width:100vw;max-width:100vw;margin-left:calc(50% - 50vw);margin-right:calc(50% - 50vw)}
.lead-body{min-width:0;width:100%;box-sizing:border-box}
.t-leadimg{min-width:0}
.t-cell{grid-template-columns:1fr 96px;gap:14px;min-width:0}
.t-thumb{width:96px;aspect-ratio:3/2;height:auto;flex-shrink:0}
.a-row{grid-template-columns:36px 1fr 96px;gap:12px;padding:18px 0;min-width:0}
.a-thumb{width:96px;aspect-ratio:3/2;height:auto;flex-shrink:0}
.l-row{grid-template-columns:96px 1fr;gap:14px;min-width:0}
.l-thumb{width:96px;aspect-ratio:3/2;height:auto;flex-shrink:0}
.tband{padding:16px;border-radius:18px}
.ticket{flex-direction:column}
.tmain .tkhd{border-radius:16px 16px 0 0;padding:12px 16px;font-size:11px;letter-spacing:.16em}
.tkhd2{border-radius:0;padding:12px 16px}
.tbody{padding:16px 16px 12px}
.tship{width:68%;right:-16px;bottom:-8px}
.bph1{font-size:28px!important;line-height:1.35;margin:14px 0 18px!important}
.coderow{flex-wrap:wrap;gap:12px!important}
.tin .coderow{gap:12px!important}
.route{flex-wrap:wrap;gap:10px!important;max-width:100%!important}
.route .rc{font-size:18px!important}
.rc{font-size:18px!important}
.tfoot{flex-wrap:wrap;gap:12px;padding:12px 16px 16px}
.tfoot .coderow{gap:14px!important}
.tfoot .bar{width:100%!important;max-width:180px}
.tstub{display:none}
.snotch{display:none}
.tsbody{padding:16px}
.abody .tbl{display:table;max-width:none;margin:0}
.abody .tbl-scroll{margin:20px 0}
.kbox{padding:16px 18px;margin:8px 0 24px}
.tocbox{padding:16px 18px;margin:0 0 24px}
.tip{padding:16px 18px;border-left-width:4px}
.authbox{flex-direction:column;gap:16px;padding:18px 20px}
.ftbar{flex-direction:column;gap:12px;text-align:center}
.nowrap{white-space:normal}
}
</style>
</head>
