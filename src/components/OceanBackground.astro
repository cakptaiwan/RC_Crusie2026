---
/** Fixed multi-layer ocean background — CSS only, zero JS */
---
<div class="ocean-bg" aria-hidden="true" data-enter="fade" data-enter-delay="0">
  <div class="ocean-bg__gradient"></div>
  <div class="ocean-bg__glow ocean-bg__glow--top"></div>
  <div class="ocean-bg__glow ocean-bg__glow--bottom"></div>
  <div class="ocean-bg__waves"></div>
  <div class="ocean-bg__depth"></div>
</div>
