---
/**
 * PostCard — renders a single post in one of two layouts:
 *   'card'  — vertical card with image header (default, used in grids)
 *   'list'  — horizontal thumbnail + text (used in Latest Posts)
 *
 * Images are served via astro:assets <Image> for automatic format conversion
 * (WebP/AVIF) and layout-shift prevention.  External domains must be listed
 * in astro.config.mjs → image.remotePatterns.
 */
import { Image } from 'astro:assets';

export interface Props {
  category: string;
  title: string;
  excerpt: string;
  image?: string | null;
  date: string;
  author: string;
  comments?: number;
  likes?: number;
  url?: string;
  featured?: boolean;
  variant?: 'card' | 'list' | 'feature';
  imageHeight?: string;
}

const {
  category,
  title,
  excerpt,
  image,
  url = '#',
  date,
  featured = false,
  variant = 'card',
  imageHeight = 'h-[180px]',
} = Astro.props;

/* Placeholder path (static, bundled by Astro) */
const PLACEHOLDER_BG = 'bg-blue-light';
---

{variant === 'feature' ? (
  /* ── Feature variant: wide editorial card for trending lead ── */
  <article class="ocean-event-card group relative overflow-hidden rounded-2xl">
    <a href={url} class="grid min-h-[220px] md:min-h-[260px] md:grid-cols-[1.15fr_1fr]">
      {image ? (
        <div class="relative min-h-[180px] overflow-hidden md:min-h-0">
          <Image
            src={image}
            alt={title}
            width={800}
            height={480}
            loading="lazy"
            class="ocean-event-card__img absolute inset-0 h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#061556]/20 via-transparent to-[#061556]/55 md:bg-gradient-to-l md:from-transparent md:via-[#061556]/25 md:to-[#061556]/88" />
        </div>
      ) : (
        <div class="min-h-[180px] bg-gradient-to-br from-[#061556] via-[#0a2a6e] to-[#0073BB] md:min-h-0" />
      )}
      <div class="relative flex flex-col justify-end bg-[#061556]/92 p-6 md:bg-[#061556]/78 md:p-8">
        <p class="section-eyebrow mb-2">Trending</p>
        <span class="mb-3 inline-block w-fit rounded-full bg-[#0073BB] px-3 py-1 text-[12px] font-semibold text-white">
          {category}
        </span>
        <h3 class="font-serif text-xl font-bold leading-snug text-white md:text-2xl">
          {title}
        </h3>
        <p class="mt-3 line-clamp-2 font-sans text-[14px] leading-[1.75] text-white/55">
          {excerpt}
        </p>
        <div class="mt-4 flex items-center justify-between border-t border-white/10 pt-4">
          <span class="font-sans text-[12px] text-white/45">{date}</span>
          <span class="font-sans text-[12px] font-semibold text-[#FEBD11] transition-colors group-hover:text-white">
            閱讀全文 →
          </span>
        </div>
      </div>
    </a>
  </article>
) : variant === 'list' ? (
  /* ── List variant: 96×72 thumbnail left, text right ── */
  <article class="group flex gap-3 py-3 first:pt-0 last:pb-0">
    {image ? (
      <a href={url} class="shrink-0 overflow-hidden rounded-card">
        <Image
          src={image}
          alt={title}
          width={96}
          height={72}
          loading="lazy"
          class="h-[72px] w-[96px] object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </a>
    ) : (
      <a
        href={url}
        class="flex h-[72px] w-[96px] shrink-0 items-center justify-center rounded-card bg-blue-light text-blue-accent"
        aria-hidden="true"
      >
        <svg class="h-5 w-5 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </a>
    )}
    <div class="min-w-0 flex-1">
      <span class="mb-1 inline-block rounded-full bg-[#0073BB] px-2.5 py-1 text-[12px] font-semibold text-white">
        {category}
      </span>
      <h3 class="mb-1 line-clamp-2 font-sans text-[15px] font-semibold leading-[1.6] text-ink transition-colors group-hover:text-[#0073BB]">
        <a href={url}>{title}</a>
      </h3>
      <p class="font-sans text-[12px] text-ink-soft">{date}</p>
    </div>
  </article>
) : (
  /* ── Card variant: image top, editorial content below ── */
  <article class="ds-card motion-card-lift group">
    {image ? (
      <a href={url} class="block overflow-hidden">
        <Image
          src={image}
          alt={title}
          width={700}
          height={394}
          loading="lazy"
          class:list={[imageHeight, 'w-full object-cover transition-transform duration-500 group-hover:scale-105']}
        />
      </a>
    ) : (
      /* No-image placeholder maintains card aspect ratio */
      <a href={url} class:list={[imageHeight, 'flex items-center justify-center bg-blue-light text-blue-accent/30']}>
        <svg class="h-10 w-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </a>
    )}

    <div class="p-4">
      <!-- Category: editorial uppercase label -->
      <p class="section-eyebrow mb-2">
        {category}
      </p>

      <!-- Article title -->
      <h2
        class:list={[
          'mb-2 font-serif font-semibold leading-[1.45] text-[#061556] transition-colors group-hover:text-[#0073BB]',
          featured ? 'text-lg md:text-xl' : 'text-base md:text-lg',
        ]}
      >
        <a href={url}>{title}</a>
      </h2>

      <!-- Excerpt -->
      <p class="mb-4 line-clamp-2 font-sans text-[14px] leading-[1.75] text-ink-soft">{excerpt}</p>

      <!-- Footer: date left, CTA right -->
      <div class="flex items-center justify-between border-t border-canvas-ceramic pt-3">
        <span class="text-[12px] text-ink-soft">{date}</span>
        <a
          href={url}
          class="text-[12px] font-semibold text-[#0073BB] transition-colors hover:text-[#061556]"
        >
          閱讀更多 →
        </a>
      </div>
    </div>
  </article>
)}
