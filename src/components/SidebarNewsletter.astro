---
---

<div class="sidebar-widget">
  <div class="sidebar-section-header">
    <span class="sidebar-section-title">訂閱電子報</span>
  </div>

  <div id="newsletter-form-wrap">
    <label class="mb-1.5 block text-[13px] font-medium text-ink-soft">
      Email 郵件 <span class="ml-0.5 text-semantic-error">*</span>
    </label>
    <div class="flex w-full overflow-hidden rounded-full border border-blue-accent/35 bg-white shadow-sm">
      <input
        id="newsletter-email"
        type="email"
        required
        placeholder="在這填入 Email"
        class="min-w-0 flex-1 border-0 bg-transparent px-4 py-2.5 text-[14px] text-ink outline-none placeholder:text-ink-soft/70"
      />
      <button
        id="newsletter-btn"
        type="button"
        class="shrink-0 bg-blue-accent px-5 py-2.5 text-[14px] font-semibold text-white transition-colors duration-200 hover:bg-blue-brand"
      >
        訂閱
      </button>
    </div>
    <p id="newsletter-msg" class="mt-2 text-[13px] hidden"></p>
  </div>

  <p class="mt-3 text-[13px] leading-relaxed text-ink-soft">
    我會分享皇家加勒比遊輪的搭船攻略、航線情報與旅人心得。千萬不可錯過！
  </p>
</div>

<script>
  const btn = document.getElementById('newsletter-btn');
  const input = document.getElementById('newsletter-email') as HTMLInputElement;
  const msg = document.getElementById('newsletter-msg');

  btn?.addEventListener('click', async () => {
    const email = input?.value.trim() ?? '';
    if (!email || !email.includes('@')) {
      if (msg) { msg.textContent = '請輸入有效的 Email'; msg.className = 'mt-2 text-[13px] text-red-500 block'; }
      return;
    }

    if (btn) {
      btn.textContent = '送出中…';
      btn.setAttribute('disabled', 'true');
    }
    if (msg) msg.className = 'mt-2 text-[13px] hidden';

    try {
      const formData = new FormData();
      formData.append('email', email);

      const res = await fetch('/api/newsletter', { method: 'POST', body: formData });
      const data = await res.json();

      if (!res.ok || !data.ok) {
        if (msg) {
          msg.textContent = data.error ?? '發生錯誤，請稍後再試';
          msg.className = 'mt-2 text-[13px] text-red-500 block';
        }
        if (btn) btn.textContent = '訂閱';
        return;
      }

      if (msg) {
        msg.textContent = `✅ ${data.message ?? '訂閱成功！感謝你的支持。'}`;
        msg.className = 'mt-2 text-[13px] text-green-600 block';
      }
      if (input) input.value = '';
      if (btn) btn.textContent = '已訂閱';
    } catch {
      if (msg) {
        msg.textContent = '網路連線異常，請確認網路後再試。';
        msg.className = 'mt-2 text-[13px] text-red-500 block';
      }
      if (btn) btn.textContent = '訂閱';
    } finally {
      btn?.removeAttribute('disabled');
    }
  });
</script>
