---
---

<div
  id="contact-backdrop"
  class="cp-backdrop cp-backdrop--closed"
  aria-hidden="true"
  data-contact-backdrop
></div>

<aside
  id="contact-panel"
  class="cp-panel cp-panel--closed"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-panel-title"
  aria-hidden="true"
  data-contact-panel
>
  <header class="cp-header">
    <span id="contact-panel-title" class="cp-title srf">聯絡我們</span>
    <button
      type="button"
      id="contact-close"
      class="cp-close"
      aria-label="關閉聯絡表單"
    >
      <svg class="cp-close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </header>

  <div class="cp-body">
    <p class="cp-intro">
      想知道什麼遊輪資訊，對於網站有什麼指教，都請不吝告訴我。
    </p>

    <form id="contact-form" class="cp-form" novalidate>
      <div class="cp-field">
        <label for="contact-name" class="cp-label">姓名 <span class="cp-required">*</span></label>
        <input id="contact-name" name="name" type="text" required autocomplete="name" class="cp-input" placeholder="請輸入姓名" />
      </div>

      <div class="cp-field">
        <label for="contact-phone" class="cp-label">聯絡電話 <span class="cp-required">*</span></label>
        <input id="contact-phone" name="phone" type="tel" required autocomplete="tel" class="cp-input" placeholder="09xx-xxx-xxx" />
      </div>

      <div class="cp-field">
        <label for="contact-email" class="cp-label">電子郵件 <span class="cp-required">*</span></label>
        <input id="contact-email" name="email" type="email" required autocomplete="email" class="cp-input" placeholder="your@email.com" />
      </div>

      <div class="cp-field">
        <label for="contact-subject" class="cp-label">主題 <span class="cp-required">*</span></label>
        <input id="contact-subject" name="subject" type="text" required class="cp-input" placeholder="想詢問的主題" />
      </div>

      <div class="cp-field">
        <label for="contact-message" class="cp-label">留言內容 <span class="cp-required">*</span></label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="8"
          class="cp-input cp-textarea"
          placeholder="請描述你的問題或建議"
        ></textarea>
      </div>

      <input type="text" name="website" tabindex="-1" autocomplete="off" class="cp-honeypot" aria-hidden="true" />

      <div id="contact-status" class="cp-status cp-status--hidden" role="status" aria-live="polite"></div>

      <button type="submit" id="contact-submit" class="cp-submit">
        <span id="contact-submit-label">送出訊息</span>
        <svg id="contact-submit-spinner" class="cp-spinner cp-spinner--hidden" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle class="cp-spinner-track" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="cp-spinner-head" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>
    </form>
  </div>
</aside>

<script is:inline>
  (() => {
    const panel = document.querySelector('[data-contact-panel]');
    const backdrop = document.querySelector('[data-contact-backdrop]');
    const closeBtn = document.getElementById('contact-close');
    const openBtns = document.querySelectorAll('[data-contact-open]');
    const form = document.getElementById('contact-form');
    const statusEl = document.getElementById('contact-status');
    const submitBtn = document.getElementById('contact-submit');
    const submitLabel = document.getElementById('contact-submit-label');
    const spinner = document.getElementById('contact-submit-spinner');

    if (!panel || !backdrop || !form || !statusEl || !submitBtn) return;

    const setStatus = (type, message) => {
      statusEl.classList.remove('cp-status--hidden', 'cp-status--success', 'cp-status--error');
      if (type === 'success') {
        statusEl.classList.add('cp-status--success');
      } else if (type === 'error') {
        statusEl.classList.add('cp-status--error');
      } else {
        statusEl.classList.add('cp-status--hidden');
        statusEl.textContent = '';
        return;
      }
      statusEl.textContent = message;
    };

    const setLoading = (loading) => {
      submitBtn.disabled = loading;
      submitLabel.textContent = loading ? '送出中…' : '送出訊息';
      spinner?.classList.toggle('cp-spinner--hidden', !loading);
    };

    const openPanel = () => {
      panel.classList.remove('cp-panel--closed');
      panel.setAttribute('aria-hidden', 'false');
      backdrop.classList.remove('cp-backdrop--closed');
      backdrop.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    };

    const closePanel = () => {
      panel.classList.add('cp-panel--closed');
      panel.setAttribute('aria-hidden', 'true');
      backdrop.classList.add('cp-backdrop--closed');
      backdrop.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    openBtns.forEach((btn) => btn.addEventListener('click', openPanel));
    closeBtn?.addEventListener('click', closePanel);
    backdrop.addEventListener('click', closePanel);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.getAttribute('aria-hidden') === 'false') {
        closePanel();
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setStatus('clear');

      const formData = new FormData(form);
      const payload = {
        name: String(formData.get('name') ?? ''),
        phone: String(formData.get('phone') ?? ''),
        email: String(formData.get('email') ?? ''),
        subject: String(formData.get('subject') ?? ''),
        message: String(formData.get('message') ?? ''),
        website: String(formData.get('website') ?? ''),
      };

      setLoading(true);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok || !result.ok) {
          setStatus('error', result.error ?? '訊息送出失敗，請稍後再試。');
          return;
        }

        setStatus('success', result.message ?? '訊息已送出，感謝你的聯絡！');
        form.reset();
      } catch {
        setStatus('error', '網路連線異常，請確認網路後再試。');
      } finally {
        setLoading(false);
      }
    });
  })();
</script>

<style is:global>
  .cp-backdrop {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: rgba(11, 42, 74, 0.25);
    backdrop-filter: blur(2px);
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .cp-backdrop--closed {
    pointer-events: none;
    opacity: 0;
  }

  .cp-panel {
    position: fixed;
    inset: 0 0 0 auto;
    z-index: 61;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 42rem;
    background: #fff;
    box-shadow: -10px 0 40px rgba(11, 42, 74, 0.14);
    transform: translateX(0);
    transition: transform 0.3s ease-out;
    font-family: 'Noto Sans TC', sans-serif;
    color: #0b2a4a;
  }

  .cp-panel--closed {
    transform: translateX(100%);
  }

  .cp-header {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(11, 42, 74, 0.16);
    padding: 20px 24px;
  }

  @media (min-width: 768px) {
    .cp-header {
      padding: 20px 32px;
    }
  }

  .cp-title {
    font-size: 21px;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #0b2a4a;
    margin: 0;
  }

  .cp-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: #51677c;
    cursor: pointer;
    transition: background 0.25s, color 0.25s;
  }

  .cp-close:hover {
    background: #edf4fa;
    color: #0b2a4a;
  }

  .cp-close-icon {
    width: 20px;
    height: 20px;
  }

  .cp-body {
    min-height: 0;
    flex: 1;
    overflow-y: auto;
    padding: 24px;
  }

  @media (min-width: 768px) {
    .cp-body {
      padding: 28px 32px;
    }
  }

  .cp-intro {
    margin: 0 0 24px;
    font-size: 15px;
    line-height: 1.85;
    color: #51677c;
  }

  .cp-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .cp-field {
    display: flex;
    flex-direction: column;
  }

  .cp-label {
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #51677c;
  }

  .cp-required {
    color: #c82014;
  }

  .cp-input {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid rgba(11, 42, 74, 0.3);
    padding: 12px 14px;
    font-size: 15px;
    font-family: inherit;
    color: #0b2a4a;
    background: #fff;
    outline: none;
    transition: border-color 0.25s;
  }

  .cp-input::placeholder {
    color: #8aa3b9;
  }

  .cp-input:focus {
    border-color: #0b2a4a;
  }

  .cp-textarea {
    min-height: 180px;
    resize: vertical;
    line-height: 1.7;
  }

  .cp-honeypot {
    display: none;
  }

  .cp-status {
    padding: 14px 16px;
    font-size: 15px;
    line-height: 1.6;
    border: 1px solid transparent;
  }

  .cp-status--hidden {
    display: none;
  }

  .cp-status--success {
    display: block;
    background: #edf4fa;
    color: #2a628f;
    border-color: rgba(42, 98, 143, 0.2);
  }

  .cp-status--error {
    display: block;
    background: #fef2f2;
    color: #b91c1c;
    border-color: rgba(185, 28, 28, 0.2);
  }

  .cp-submit {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: none;
    background: #0b2a4a;
    color: #fff;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.08em;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.25s;
  }

  .cp-submit:hover:not(:disabled) {
    opacity: 0.85;
  }

  .cp-submit:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .cp-spinner {
    width: 16px;
    height: 16px;
    animation: cp-spin 1s linear infinite;
  }

  .cp-spinner--hidden {
    display: none;
  }

  .cp-spinner-track {
    opacity: 0.25;
  }

  .cp-spinner-head {
    opacity: 0.75;
  }

  @keyframes cp-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
