---
import SidebarPillForm from './SidebarPillForm.astro';
---

<div class="sidebar-widget">
  <div class="sidebar-section-header">
    <span class="sidebar-section-title">站內搜尋</span>
  </div>

  <SidebarPillForm
    action="/search"
    name="q"
    type="search"
    label="關鍵字"
    placeholder="輸入關鍵字…"
    buttonLabel="搜尋"
    ariaLabel="站內搜尋"
  />

  <p class="mt-3 text-[13px] leading-relaxed text-ink-soft">
    搜尋文章標題與摘要，快速找到你需要的遊輪資訊。
  </p>
</div>
