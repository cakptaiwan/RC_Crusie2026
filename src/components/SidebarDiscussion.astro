---
import DiscussionPanel from './DiscussionPanel.astro';
---

<div class="sidebar-widget">
  <div class="sidebar-section-header">
    <span class="sidebar-section-title">留言板</span>
  </div>

  <button
    type="button"
    data-discussion-open
    class="flex w-full items-center justify-center gap-2 rounded-full bg-blue-accent px-5 py-2.5 text-[14px] font-semibold text-white transition-colors duration-200 hover:bg-blue-brand"
  >
    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M8 12h.01M12 12h.01M16 12h.01M21 3H3c-1.1 0-2 .9-2 2v14l4-4h16c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"
      />
    </svg>
    我要留言
  </button>

  <p class="mt-3 text-[13px] leading-relaxed text-ink-soft">
    希望知道什麼類型的遊輪資訊呢，請你告訴我們
  </p>
</div>

<DiscussionPanel />
