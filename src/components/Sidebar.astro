---
import { siteAuthor } from '../data/site-author';
import { getAllPosts } from '../lib/notion';
import { getSidebarCategories } from '../lib/sidebar-categories';
import SidebarDiscussion from './SidebarDiscussion.astro';
import SidebarNewsletter from './SidebarNewsletter.astro';
import SidebarSearch from './SidebarSearch.astro';

const categories = getSidebarCategories(await getAllPosts());

---

<aside class="w-full space-y-6">

  <!-- 關於我 -->
  <div class="sidebar-widget">
    <div class="sidebar-section-header">
      <span class="sidebar-section-title">關於我</span>
    </div>
    <div class="text-center">
      <img
        src={siteAuthor.avatar}
        alt={`Loyal to Royal ${siteAuthor.name}`}
        width="80"
        height="80"
        loading="lazy"
        class="mx-auto mb-3 h-20 w-20 rounded-md object-contain"
      />
      <p class="text-left text-[14px] leading-relaxed text-ink-soft">
        {siteAuthor.bio}
        <a href={siteAuthor.aboutUrl} class="ml-1 font-semibold text-blue-accent hover:underline">了解更多</a>
      </p>
    </div>
  </div>

  <SidebarDiscussion />
  <SidebarNewsletter />
  <SidebarSearch />

  <!-- 文章分類（僅顯示有文章的分類） -->
  {categories.length > 0 && (
    <div class="sidebar-widget" data-sidebar-categories>
      <div class="sidebar-section-header">
        <span class="sidebar-section-title">文章分類</span>
      </div>
      <ul class="space-y-0.5">
        {categories.map(({ name, count, href }) => (
          <li data-category-count={count}>
            <a
              href={href}
              class="group flex items-center justify-between border-b border-canvas-ceramic py-2 text-[14px] font-medium text-ink-soft transition-colors hover:text-blue-accent"
            >
              <span>{name}</span>
              <span
                class="flex h-5 w-5 items-center justify-center rounded-full bg-blue-light text-[10px] font-bold text-blue-brand transition-colors group-hover:bg-blue-accent group-hover:text-onDark"
                data-count={count}
              >
                {count}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

</aside>
