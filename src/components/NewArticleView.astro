---
import { siteAuthor } from '../data/site-author';
import { getCategoryHrefBySubPage } from '../data/new-layout-nav';
import { mapArticleBodyHtml, estimateReadMinutes, countArticleHeading2 } from '../lib/map-article-body';
import { postImage } from '../lib/cloudinary-image';
import { newArticleUrl, newHomeUrl } from '../lib/new-article-url';
import { getPosts } from '../lib/notion';
import type { Post } from '../lib/notion';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const mappedBody = mapArticleBodyHtml(post.body);
const heading2Count = countArticleHeading2(post.body);
const showTOC = post.showTOC || heading2Count >= 6;
const readMinutes = estimateReadMinutes(post.excerpt, post.body);
const categoryHref = getCategoryHrefBySubPage(post.subPage || post.category);
const postImageUrl = postImage(post.image, 'hero');

const formattedDate = post.date
  ? new Date(post.date).toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })
  : '';

const allPosts = await getPosts();
const relatedPosts = allPosts
  .filter((p) => p.category === post.category && p.id !== post.id)
  .slice(0, 3);
---

<div class="crumb">
  <a href={newHomeUrl}>首頁</a><span>/</span>
  <a href={categoryHref}>{post.subPage || post.category}</a><span>/</span>
  <span class="crumb-title">{post.title}</span>
</div>

<div class="ah rise d1">
  <span class="stamp">{post.subPage || post.category}</span>
  <h1 class="ah1 srf">{post.title}</h1>
  <div class="ameta">
    <span>{formattedDate}</span><span>·</span>
    <span>{post.author || '皇家旅人'}</span><span>·</span>
    <span>閱讀約 {readMinutes} 分鐘</span>
  </div>
</div>

{post.image && (
  <div class="aheroimg zi rev">
    <img class="ph" src={postImageUrl} alt={post.title} fetchpriority="high" />
  </div>
)}

<div class="abody">
  {post.excerpt && <p>{post.excerpt}</p>}

  {showTOC && (
    <details class="tocbox rev">
      <summary class="toch">
        <span class="toch-label">
          <span class="toch-icon" aria-hidden="true">📑</span>
          本文目錄 · CONTENTS
        </span>
        <span class="toch-chev" aria-hidden="true"></span>
      </summary>
      <div class="toc-panel">
        <div class="toc-panel-inner">
          <ol id="toc-list" class="toclist"></ol>
        </div>
      </div>
    </details>
  )}

  {mappedBody && <div set:html={mappedBody} />}

  <div class="tagrow rev">
    <span class="ovl" style="font-size:11px">Tags</span>
    <span class="stamp">{post.subPage || post.category}</span>
  </div>

  <div class="authbox rev">
    <span class="avat srf">{siteAuthor.name.slice(0, 1)}</span>
    <span>
      <span class="fw7 fs15 navy">{siteAuthor.name} · {siteAuthor.tagline}</span>
      <span class="sbp" style="display:block;margin-top:8px">{siteAuthor.bio}</span>
    </span>
  </div>

  {
    relatedPosts.length > 0 && (
      <>
        <div class="sec-head rev" style="margin-top:64px">
          <div>
            <div class="ovl">Related · 延伸閱讀</div>
            <h2 class="a-h2 srf" style="font-size:32px">相關文章</h2>
          </div>
        </div>
        <div class="l-grid rev">
          {
            relatedPosts.map((related, index) => (
              <a
                class="l-row"
                href={newArticleUrl(related.id)}
                style={index < 2 ? 'border-top:none;padding-top:0' : undefined}
              >
                <span class="l-thumb zi">
                  <img class="ph" src={postImage(related.image, 'thumb')} alt={related.title} loading="lazy" />
                </span>
                <span>
                  <span class="a-cat">{related.subPage || related.category}</span>
                  <span class="l-t">{related.title}</span>
                  <span class="a-date">{related.date?.slice(0, 10)}</span>
                </span>
              </a>
            ))
          }
        </div>
      </>
    )
  }
</div>

{showTOC && (
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tocList = document.getElementById('toc-list');
      if (!tocList) return;
      const headings = document.querySelectorAll('.abody h2.bh2');
      if (headings.length === 0) {
        tocList.closest('.tocbox')?.remove();
        return;
      }
      headings.forEach((h, i) => {
        const id = `heading-${i}`;
        h.id = id;
        const li = document.createElement('li');
        li.className = 'tocli';
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = h.textContent ?? '';
        li.appendChild(a);
        tocList.appendChild(li);
      });
    });
  </script>
)}
