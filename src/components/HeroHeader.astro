---
/**
 * HeroHeader — Navigation + Hero as one cohesive premium unit (homepage)
 */
import { Image } from 'astro:assets';
import NavStrip from './NavStrip.astro';
import heroCruise from '../assets/images/hero-aerial-ship.png';
import type { Post } from '../lib/notion';

interface Props {
  post: Post;
}

const { post } = Astro.props;
---

<section id="hero-shell" class="relative mb-0 w-full" aria-label="首頁主視覺">
  <NavStrip overlay />

  <div
    id="hero-section"
    class="group relative w-full overflow-hidden"
    style="height: clamp(480px, 62vh, 680px); box-shadow: 0 16px 56px rgba(6,21,86,0.24), 0 2px 8px rgba(6,21,86,0.10);"
  >
    <!-- Parallax background -->
    <div
      data-parallax="0.38"
      class="absolute inset-0 overflow-hidden will-change-transform"
      data-enter="fade"
      data-enter-delay="100"
    >
      <Image
        src={heroCruise}
        alt="俯瞰碧綠海面上航行的皇家加勒比郵輪，甲板上網球場與泳池清晰可見"
        width={1024}
        height={634}
        quality={95}
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        class="hero-parallax-img absolute inset-0 h-full w-full object-cover object-right"
      />
    </div>

    <!-- Navy gradient overlays -->
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#061556]/82 via-[#061556]/28 to-transparent"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-[#061556]/55 via-transparent to-[#0073BB]/10"
      aria-hidden="true"
    />
    <!-- Top vignette — blends with overlay nav -->
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[#061556]/70 to-transparent"
      aria-hidden="true"
    />

    <!-- Decorative asymmetry -->
    <span
      class="pointer-events-none absolute right-6 top-24 hidden select-none font-serif text-[140px] font-bold leading-none text-white/[0.04] lg:block xl:right-16 xl:text-[180px]"
      aria-hidden="true"
    >RC</span>
    <div
      class="pointer-events-none absolute right-[18%] top-[22%] hidden h-24 w-px origin-top rotate-[18deg] md:block"
      style="background: linear-gradient(to bottom, rgba(254,189,17,0.45), rgba(254,189,17,0.08), transparent);"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute bottom-[28%] right-8 hidden h-px w-32 md:block lg:right-16 lg:w-48"
      style="background: linear-gradient(to right, transparent, rgba(255,255,255,0.22), transparent);"
      aria-hidden="true"
    />

    <!-- Scroll indicator -->
    <div
      class="absolute right-5 top-1/2 hidden -translate-y-1/2 flex-col items-center gap-3 lg:flex"
      aria-hidden="true"
    >
      <span
        class="text-[9px] font-medium uppercase tracking-[0.28em] text-white/30"
        style="writing-mode: vertical-rl;"
      >Scroll</span>
      <div class="h-20 w-px bg-gradient-to-b from-transparent via-[#0073BB]/50 to-transparent" />
    </div>

    <!-- Asymmetric editorial cluster — bottom-left -->
    <div
      class="absolute bottom-6 left-4 z-10 sm:bottom-10 sm:left-8 md:bottom-12 md:left-12 lg:left-16"
      data-enter="up"
      data-enter-delay="280"
    >
      <!-- Primary grey panel -->
      <a
        href={post.url}
        class="hero-panel group/panel relative block max-w-[300px] overflow-visible rounded-2xl px-5 pb-5 pt-5 transition-transform duration-500 ease-out hover:-translate-y-1.5 sm:max-w-[360px] sm:px-6 sm:pb-6 sm:pt-6 md:max-w-[440px] md:px-7 md:pb-7 md:pt-7 lg:max-w-[480px]"
        style="background: rgba(6,21,86,0.62); backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px); border: 1px solid rgba(255,255,255,0.14); box-shadow: 0 20px 56px rgba(6,21,86,0.42), inset 0 1px 0 rgba(255,255,255,0.10);"
      >
        <h1
          class="font-serif text-[1.25rem] font-bold leading-[1.45] text-white sm:text-[1.5rem] sm:leading-[1.5] md:text-[1.75rem] md:leading-[1.45] lg:text-[2.25rem] lg:leading-[1.35]"
        >
          喜歡旅行、喜歡遊輪、<br class="hidden sm:inline" />無可救藥的喜歡皇家加勒比遊輪
        </h1>
        <p class="mt-4 line-clamp-3 font-sans text-[14px] leading-[1.75] text-white/60 md:text-[15px]">
          我永遠記得跟家人，一起在皇家加勒比游輪上度假的時光，游泳池畔的樂隊、多樣異國美食、星光下的電影、游完泳後的霜淇淋，都會讓我想再重返加勒比遊輪.....
        </p>
      </a>

      <!-- Offset meta box -->
      <div
        class="absolute -bottom-3 right-0 z-20 translate-x-2 rounded-xl px-4 py-2.5 sm:-bottom-4 sm:translate-x-6 md:translate-x-10"
        style="background: rgba(0,115,187,0.32); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.14);"
      >
        <span class="font-sans text-[12px] tracking-wide text-white/75">
          {post.date} · {post.author}
        </span>
      </div>
    </div>
  </div>

  <!-- Seamless transition into page content -->
  <div
    class="pointer-events-none absolute -bottom-px left-0 right-0 h-16 bg-gradient-to-b from-transparent to-[#F8FAFC]/80"
    aria-hidden="true"
  />
</section>
