---
import NewLayout from '../layouts/NewLayout.astro';
import HomePageSidebar from '../components/HomePageSidebar.astro';
import { getCategoryHrefBySubPage } from '../data/new-layout-nav';
import { newArticleUrl } from '../lib/new-article-url';
import { getAllPosts, getFeaturedPosts, getPosts } from '../lib/notion';
import type { Post } from '../lib/notion';

const [featured, homePosts, allPosts] = await Promise.all([
  getFeaturedPosts(),
  getPosts('HOME'),
  getAllPosts(),
]);

const featuredIds = new Set(featured.map((p) => p.id));
const featuredPosts: Post[] = [
  ...featured,
  ...homePosts.filter((p) => !featuredIds.has(p.id)),
].slice(0, 5);
const [featuredLead, ...featuredRows] = featuredPosts;

/** 熱門：沿用正式站 ShowOnHome 邏輯（無真實熱門度） */
const trending: Post[] = [...homePosts.slice(2, 6), ...homePosts.slice(0, 1)].slice(0, 5);
const [trendingLead, ...trendingCells] = trending;

/** 最新：全站依日期排序（getAllPosts 已 desc） */
const latestPosts = allPosts.slice(0, 4);

const featuredViewAll = featuredLead
  ? getCategoryHrefBySubPage(featuredLead.subPage, 'onboard-activities')
  : '/category/onboard-activities';

const formatDate = (date: string) => (date ? date.slice(0, 10) : '');
const postImage = (image: string | null) => image ?? '/assets/ships.png';
const padNum = (n: number) => String(n).padStart(2, '0');
---

<NewLayout
  title="皇家加勒比遊輪攻略｜新手入門到老手進階"
  description="皇家加勒比遊輪全攻略，從新手訂票入門到老手玩法進階，船上活動、岸上行程、聰明花費技巧一次掌握，實際搭乘經驗分享，給華人旅客最實用的皇家加勒比遊輪資訊。"
>
  <!-- Hero 登船證：設計稿靜態品牌形象 -->
  <div class="c-hero" style="margin:40px 56px 0">
    <div class="tband">
      <div class="ticket rise d1">
        <div class="tmain">
          <div class="tkhd"><span>BOARDING PASS · 登船證</span><span style="opacity:.65">ROYAL CRUISER</span></div>
          <div class="tbody">
            <img class="tship" src="/assets/ship-blueprint.png" alt="皇家加勒比遊輪藍圖線稿" />
            <div class="tin">
              <div class="coderow" style="gap:44px">
                <span><span class="codelbl">PASSENGER</span><span class="codeval" style="display:block">每一位喜愛遊輪的華人旅人</span></span>
                <span><span class="codelbl">CLASS</span><span class="codeval" style="display:block">海景陽台艙</span></span>
              </div>
              <h1 class="bph1 srf rise d2" style="font-size:44px;margin:18px 0 24px">上船那一刻起，就沒有行程。</h1>
              <div class="route rise d3" style="max-width:540px">
                <span><span class="rl">FROM</span><span class="rc" style="display:block;font-size:30px">TAIWAN</span><span class="rsub">基隆 KEELUNG</span></span>
                <span class="rline">
                  <span class="rdot"></span><span class="rdash"></span>
                  <svg width="42" height="28" viewBox="0 0 46 30" fill="none" aria-hidden="true">
                    <path d="M6 20 L40 20 L35 27 L10 27 Z" fill="#0B2A4A"></path>
                    <path d="M12 15 L32 15 L32 20 L12 20 Z" fill="#0B2A4A"></path>
                    <path d="M16 10 L27 10 L27 15 L16 15 Z" fill="#0B2A4A"></path>
                    <rect x="20" y="4" width="4" height="6" fill="#0B2A4A"></rect>
                    <circle cx="15" cy="17.5" r="1.1" fill="#EDF4FA"></circle>
                    <circle cx="20" cy="17.5" r="1.1" fill="#EDF4FA"></circle>
                    <circle cx="25" cy="17.5" r="1.1" fill="#EDF4FA"></circle>
                    <circle cx="30" cy="17.5" r="1.1" fill="#EDF4FA"></circle>
                  </svg>
                  <span class="rdash"></span><span class="rdot"></span>
                </span>
                <span style="text-align:right"><span class="rl">TO</span><span class="rc" style="display:block;font-size:30px">ALASKA</span><span class="rsub">阿拉斯加</span></span>
              </div>
            </div>
          </div>
          <div class="tfoot">
            <div class="coderow" style="gap:40px">
              <span><span class="codelbl">DECK</span><span class="codeval mono" style="display:block">05</span></span>
              <span><span class="codelbl">GATE</span><span class="codeval mono" style="display:block">12</span></span>
              <span><span class="codelbl">YEAR</span><span class="codeval mono" style="display:block">2026</span></span>
            </div>
            <span class="tnote">開航前 60 分鐘停止登船 · GATE CLOSES 60 MIN BEFORE DEPARTURE</span>
            <span class="bar" style="width:180px;height:28px"></span>
          </div>
        </div>
        <div class="tstub">
          <span class="snotch" style="top:-16px"></span><span class="snotch" style="bottom:-16px"></span>
          <div class="tkhd tkhd2"><span>JOURNAL</span><span style="opacity:.65">皇家旅人誌</span></div>
          <div class="tsbody">
            <span><span class="codelbl">PASSENGER</span><span class="codeval" style="display:block">華人旅人 CN TRAVELER</span></span>
            <span class="fx gap24">
              <span><span class="codelbl">FROM</span><span class="codeval" style="display:block">TAIWAN</span></span>
              <span><span class="codelbl">TO</span><span class="codeval" style="display:block">ALASKA</span></span>
            </span>
            <span class="fx gap24">
              <span><span class="codelbl">DECK</span><span class="codeval mono" style="display:block">05</span></span>
              <span><span class="codelbl">GATE</span><span class="codeval mono" style="display:block">12</span></span>
              <span><span class="codelbl">YEAR</span><span class="codeval mono" style="display:block">2026</span></span>
            </span>
            <span class="ex2" style="font-size:12.5px;margin-top:auto">專為全球華人而寫的皇家加勒比遊輪誌——航線情報、實戰攻略與海上生活。</span>
            <span class="bar" style="height:30px;display:block"></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 精選遊輪活動 -->
  <div class="a-sec">
    <div class="a-head rev">
      <div>
        <div class="ovl">Featured Cruises · 第一手航線情報</div>
        <h2 class="a-h2 srf">精選遊輪活動</h2>
      </div>
      <a class="alink" href={featuredViewAll}>查看全部 →</a>
    </div>
    {
      featuredLead ? (
        <div class="a-grid">
          <a class="a-lead" href={newArticleUrl(featuredLead.id)} style="text-decoration:none;color:inherit">
            <div class="a-leadimg zi rev rev-l">
              <img class="ph" src={postImage(featuredLead.image)} alt={featuredLead.title} />
            </div>
            <div class="lead-body rev">
              <div class="fx ac gap12">
                <span class="a-cat">{featuredLead.subPage || featuredLead.category}</span>
                <span class="a-date">{formatDate(featuredLead.date)}</span>
              </div>
              <h3 class="a-h3 srf">{featuredLead.title}</h3>
              {featuredLead.excerpt && <p class="a-ex">{featuredLead.excerpt}</p>}
              <span class="alink">閱讀全文 →</span>
            </div>
          </a>
          <div class="rev rev-r">
            {
              featuredRows.map((post, index) => (
                <a
                  class="a-row"
                  href={newArticleUrl(post.id)}
                  style={[
                    index === 0 ? 'border-top:none;padding-top:0' : '',
                    index === featuredRows.length - 1 ? 'border-bottom:1px solid rgba(11,42,74,.16)' : '',
                  ].filter(Boolean).join(';') || undefined}
                >
                  <span class="a-num srf">{padNum(index + 1)}</span>
                  <span>
                    <span class="a-cat">{post.subPage || post.category}</span>
                    <span class="a-rt srf" style="display:block">{post.title}</span>
                    <span class="a-date">{formatDate(post.date)}</span>
                  </span>
                  <span class="a-thumb zi">
                    <img class="ph" src={postImage(post.image)} alt={post.title} />
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      ) : (
        <p class="a-ex">尚無精選文章，敬請期待。</p>
      )
    }
  </div>

  <div class="main2">
    <div>
      <!-- 熱門文章 -->
      <div class="sec-head rev" style="margin-top:0">
        <div>
          <div class="ovl">Trending Now · 旅人們最近熱讀</div>
          <h2 class="a-h2 srf">熱門文章</h2>
        </div>
        <a class="alink" href="/category/latest-news">查看全部 →</a>
      </div>
      {
        trendingLead ? (
          <>
            <a class="t-lead" href={newArticleUrl(trendingLead.id)}>
              <span class="t-leadimg zi rev rev-l" style="display:block">
                <img class="ph" src={postImage(trendingLead.image)} alt={trendingLead.title} />
              </span>
              <span class="lead-body rev">
                <span class="fx ac gap12">
                  <span class="a-cat">Trending · {trendingLead.subPage || trendingLead.category}</span>
                  <span class="a-date">{formatDate(trendingLead.date)}</span>
                </span>
                <span class="a-h3 srf" style="display:block;font-size:25px">{trendingLead.title}</span>
                {trendingLead.excerpt && <span class="a-ex" style="display:block">{trendingLead.excerpt}</span>}
                <span class="alink">閱讀全文 →</span>
              </span>
            </a>
            {
              trendingCells.length > 0 && (
                <div class="t-grid rev rev-r" style="margin-top:36px">
                  {
                    trendingCells.map((post) => (
                      <a class="t-cell" href={newArticleUrl(post.id)}>
                        <span>
                          <span class="a-cat">{post.subPage || post.category}</span>
                          <span class="l-t">{post.title}</span>
                          <span class="a-date">{formatDate(post.date)}</span>
                        </span>
                        <span class="t-thumb zi">
                          <img class="ph" src={postImage(post.image)} alt={post.title} />
                        </span>
                      </a>
                    ))
                  }
                </div>
              )
            }
          </>
        ) : (
          <p class="a-ex">尚無熱門文章，敬請期待。</p>
        )
      }

      <!-- 最新文章 -->
      <div class="sec-head rev">
        <div>
          <div class="ovl">Latest Stories · 刷新的旅遊筆記</div>
          <h2 class="a-h2 srf">最新文章</h2>
        </div>
        <a class="alink" href="/category/route-news">查看全部 →</a>
      </div>
      {
        latestPosts.length > 0 ? (
          <div class="l-grid rev">
            {
              latestPosts.map((post, index) => (
                <a
                  class="l-row"
                  href={newArticleUrl(post.id)}
                  style={index < 2 ? 'border-top:none;padding-top:0' : undefined}
                >
                  <span class="l-thumb zi">
                    <img class="ph" src={postImage(post.image)} alt={post.title} />
                  </span>
                  <span>
                    <span class="a-cat">{post.subPage || post.category}</span>
                    <span class="l-t">{post.title}</span>
                    <span class="a-date">{formatDate(post.date)}</span>
                  </span>
                </a>
              ))
            }
          </div>
        ) : (
          <p class="a-ex">尚無最新文章，敬請期待。</p>
        )
      }
    </div>

    <HomePageSidebar />
  </div>
</NewLayout>
