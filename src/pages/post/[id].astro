---
import PostLayout from '../../layouts/PostLayout.astro';
import { getAllPosts, getPostById } from '../../lib/notion';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { id } = Astro.params;
const { post: staticPost } = Astro.props;

// Use prop from getStaticPaths, or fetch individually as fallback
const post = staticPost ?? (await getPostById(id!));

if (!post) {
  return Astro.redirect('/');
}
---

<PostLayout
  id={post.id}
  category={post.category}
  title={post.title}
  excerpt={post.excerpt}
  image={post.image}
  date={post.date}
  author={post.author}
  comments={post.comments}
  likes={post.likes}
  body={post.body}
  showTOC={post.showTOC}
/>
