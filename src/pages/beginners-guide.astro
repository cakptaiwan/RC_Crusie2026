---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentLayout from '../components/ContentLayout.astro';
---

<BaseLayout
  title="新手指南"
  description="第一次搭郵輪？從訂位到上船，新手必讀完整攻略。"
>
  <ContentLayout>
    <div class="flex min-h-[40vh] flex-col items-center justify-center py-16 text-center">
      <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-light text-blue-accent">
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </span>
      <h1 class="mb-3 text-2xl font-bold text-blue-brand">新手指南</h1>
      <p class="text-body text-ink-soft">內容建置中，敬請期待。</p>
    </div>
  </ContentLayout>
</BaseLayout>
