---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentLayout from '../components/ContentLayout.astro';
---

<BaseLayout
  title="促銷資訊"
  description="最新郵輪促銷優惠、早鳥折扣、限時特價，幫你把握最佳出遊時機。"
>
  <ContentLayout>
    <div class="flex min-h-[40vh] flex-col items-center justify-center py-16 text-center">
      <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-light text-blue-accent">
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
      </span>
      <h1 class="mb-3 text-2xl font-bold text-blue-brand">促銷資訊</h1>
      <p class="text-body text-ink-soft">內容建置中，敬請期待。</p>
    </div>
  </ContentLayout>
</BaseLayout>
