---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentLayout from '../components/ContentLayout.astro';

const email = Astro.url.searchParams.get('email')?.trim() ?? '';
---

<BaseLayout title="訂閱電子報" description="訂閱皇家旅人電子報，接收皇家加勒比遊輪攻略與航線情報。">
  <ContentLayout>
    <div class="flex min-h-[40vh] flex-col items-center justify-center py-16 text-center">
      <h1 class="mb-3 text-2xl font-bold text-blue-brand">訂閱皇家旅人電子報</h1>
      {
        email ? (
          <p class="max-w-md text-body text-ink-soft">
            已收到你的訂閱意願（{email}）。電子報服務建置中，上線後將第一時間通知你。
          </p>
        ) : (
          <p class="text-body text-ink-soft">請從側欄填入 Email 訂閱，或稍後再來。</p>
        )
      }
    </div>
  </ContentLayout>
</BaseLayout>
