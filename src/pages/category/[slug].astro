---
import NewLayout from '../../layouts/NewLayout.astro';
import CategoryPageSidebar from '../../components/CategoryPageSidebar.astro';
import TravelerStoriesContent from '../../components/TravelerStoriesContent.astro';
import {
  categoryEntries,
  categoryOvlLabel,
  type CategoryEntry,
} from '../../data/new-layout-nav';
import { getPosts } from '../../lib/notion';
import { newArticleUrl, newHomeUrl } from '../../lib/new-article-url';

export async function getStaticPaths() {
  return categoryEntries.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

interface Props {
  category: CategoryEntry;
}

const { category } = Astro.props;
const isTravelerStories = category.slug === 'traveler-stories';
const posts = await getPosts(category.page, category.subPage);
const [leadPost, ...restPosts] = posts;

const pageDescription = isTravelerStories
  ? '皇家旅人的旅人故事與理念——一個無可救藥愛上皇家加勒比遊輪的台灣旅人。'
  : `${category.label}相關文章與皇家加勒比遊輪攻略。`;

const formatDate = (date: string) => (date ? date.slice(0, 10) : '');
const postImage = (image: string | null) => image ?? '/assets/ships.png';
const padNum = (n: number) => String(n).padStart(2, '0');
---

<NewLayout
  title={`${category.label} — 皇家旅人`}
  description={pageDescription}
  navActive={category.navActiveKey}
>
  <div class="crumb">
    <a href={newHomeUrl}>首頁</a><span>/</span><span>{category.label}</span>
  </div>
  <div class="main2" style="padding-top:26px">
    <div>
      <div class="sec-head rev" style="margin-top:0">
        <div>
          <div class="ovl">Category · {categoryOvlLabel(category.slug)}</div>
          <h1 class="a-h2 srf">{category.label}</h1>
        </div>
        {
          posts.length > 0 && (
            <span class="a-date" style="letter-spacing:.18em">共 {posts.length} 篇文章</span>
          )
        }
      </div>

      {isTravelerStories && <TravelerStoriesContent />}

      {
        posts.length > 0 && (
          <>
            {
              isTravelerStories && (
                <div class="sec-head rev" style="margin-top:64px">
                  <div>
                    <div class="ovl">Related · 延伸閱讀</div>
                    <h2 class="a-h2 srf" style="font-size:32px">相關文章</h2>
                  </div>
                </div>
              )
            }
            <a class="t-lead rev-l" href={newArticleUrl(leadPost.id)}>
              <span class="t-leadimg zi" style="display:block">
                <img class="ph" src={postImage(leadPost.image)} alt={leadPost.title} />
              </span>
              <span>
                <span class="fx ac gap12">
                  <span class="a-cat">{category.label}</span>
                  <span class="a-date">{formatDate(leadPost.date)}</span>
                </span>
                <span class="a-h3 srf" style="display:block;font-size:25px">{leadPost.title}</span>
                {leadPost.excerpt && (
                  <span class="a-ex" style="display:block">{leadPost.excerpt}</span>
                )}
                <span class="alink">閱讀全文 →</span>
              </span>
            </a>
            {
              restPosts.length > 0 && (
                <div class="rev-r" style="margin-top:36px">
                  {
                    restPosts.map((post, index) => (
                      <a
                        class="a-row"
                        href={newArticleUrl(post.id)}
                        style={index === restPosts.length - 1
                          ? 'border-bottom:1px solid rgba(11,42,74,.16)'
                          : undefined}
                      >
                        <span class="a-num srf">{padNum(index + 1)}</span>
                        <span>
                          <span class="a-cat">{category.label}</span>
                          <span class="a-rt srf" style="display:block">{post.title}</span>
                          <span class="a-date">{formatDate(post.date)}</span>
                        </span>
                        <span class="a-thumb zi">
                          <img class="ph" src={postImage(post.image)} alt={post.title} />
                        </span>
                      </a>
                    ))
                  }
                </div>
              )
            }
          </>
        )
      }

      {
        !isTravelerStories && posts.length === 0 && (
          <p class="a-ex" style="margin-top:24px">尚無文章，敬請期待。</p>
        )
      }
    </div>
    <CategoryPageSidebar currentSlug={category.slug} />
  </div>
</NewLayout>
