---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentLayout from '../components/ContentLayout.astro';
---

<BaseLayout
  title="費用解析"
  description="郵輪費用完整解析，包含船票、小費、飲料套餐、岸上行程等各項費用說明。"
>
  <ContentLayout>
    <div class="flex min-h-[40vh] flex-col items-center justify-center py-16 text-center">
      <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-light text-blue-accent">
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </span>
      <h1 class="mb-3 text-2xl font-bold text-blue-brand">費用解析</h1>
      <p class="text-body text-ink-soft">內容建置中，敬請期待。</p>
    </div>
  </ContentLayout>
</BaseLayout>
