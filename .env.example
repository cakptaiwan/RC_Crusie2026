# Notion Internal Integration Secret（勿填真實 Token，僅作範本）
# https://www.notion.so/my-integrations → 你的 Integration → Secrets
NOTION_TOKEN=ntn_

# Crusie2026 資料庫 ID
# https://app.notion.com/p/36363d1586cb80c68736e28ace8a8d4b
DATABASE_ID=36363d1586cb80c68736e28ace8a8d4b

# 選填：資料庫 → ⋯ → 管理資料庫 → ⋯ → 複製資料來源 ID（可略過，程式會自動解析）
# NOTION_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Resend 聯絡表單（僅伺服器端使用，勿提交至 Git）──
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# 收到聯絡表單通知的收件信箱
CONTACT_TO_EMAIL=your@email.com

# 寄件者（須為 Resend 已驗證網域，例如 noreply@royal-cruiser.com）
CONTACT_FROM_EMAIL=Royal Cruiser <noreply@royal-cruiser.com>

# ── Cloudflare Pages 正式站 ──
# 至 Cloudflare Dashboard → Workers & Pages → 你的專案 → Settings → Environment variables
# 新增上述三個變數（RESEND_API_KEY 建議設為 Secret / Encrypt）
